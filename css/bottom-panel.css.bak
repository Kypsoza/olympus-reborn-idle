/* ═══════════════════════════════════════════════════════════
   bottom-panel.css v2.0 — Hex Action Bar
   Slideur en bas : icônes hexagonales des actions possibles
   PC : tooltip au survol  |  Mobile : scroll horizontal + btn ℹ
═══════════════════════════════════════════════════════════ */

/* ══════════════════════════════════════════════════════════
   DRAWER PRINCIPAL — barre coulissante en bas
══════════════════════════════════════════════════════════ */
#bp-drawer {
  position: fixed;
  left: 0; right: 0;
  bottom: var(--hud-bottom-h, 52px);
  z-index: 300;
  background: linear-gradient(180deg, rgba(6,4,18,0.97) 0%, rgba(10,7,22,0.99) 100%);
  border-top: 1px solid rgba(200,149,26,0.4);
  box-shadow: 0 -4px 32px rgba(0,0,0,0.75);
  transition: transform 0.28s cubic-bezier(0.4,0,0.2,1);
  /* hauteur fixe = handle + title + hex bar */
  height: auto;
  min-height: 110px;
  border-radius: 16px 16px 0 0;
  display: flex;
  flex-direction: column;
}

.bp-drawer-closed { transform: translateY(calc(100% + 2px)); pointer-events: none; }
.bp-drawer-open   { transform: translateY(0); pointer-events: all; }

/* Poignée */
.bp-drag-handle {
  width: 40px; height: 4px;
  background: rgba(200,149,26,0.4);
  border-radius: 2px;
  margin: 10px auto 0;
  flex-shrink: 0;
}

/* Header : titre de la case + fermer */
.bp-drawer-header {
  display: flex;
  align-items: center;
  padding: 6px 14px 4px;
  flex-shrink: 0;
  gap: 8px;
}
.bp-drawer-title {
  font-family: Cinzel, serif;
  font-size: 14px;
  color: rgba(200,149,26,0.9);
  flex: 1;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  letter-spacing: 0.04em;
}
.bp-drawer-close {
  background: none; border: none;
  color: rgba(255,255,255,0.3);
  font-size: 16px; cursor: pointer;
  padding: 2px 6px; line-height: 1;
  flex-shrink: 0;
  transition: color 0.15s;
}
.bp-drawer-close:hover { color: #e05050; }

/* Body : contient la hex-bar */
.bp-drawer-body {
  flex: 1;
  overflow: hidden;
  padding: 4px 0 10px;
}

/* ══════════════════════════════════════════════════════════
   HEX ACTION BAR — ligne d'icônes hexagonales
══════════════════════════════════════════════════════════ */
.hex-action-bar {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 4px 16px 6px;
  overflow-x: auto;
  overflow-y: hidden;
  scrollbar-width: none;
  -webkit-overflow-scrolling: touch;
  scroll-snap-type: x proximity;
}
.hex-action-bar::-webkit-scrollbar { display: none; }

/* ── Item hexagonal ── */
.hex-item {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
  flex-shrink: 0;
  cursor: pointer;
  scroll-snap-align: start;
  transition: transform 0.12s;
  -webkit-tap-highlight-color: transparent;
}
.hex-item:hover { transform: translateY(-2px); }
.hex-item:active { transform: scale(0.94); }
.hex-item.hex-locked { opacity: 0.38; cursor: not-allowed; }
.hex-item.hex-locked:hover { transform: none; }

/* ── Hexagone SVG clippath ── */
.hex-shape {
  width: 68px;
  height: 76px;
  position: relative;
  clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(20,15,40,0.9);
  border: none;
  transition: background 0.15s;
}

.hex-item:not(.hex-locked):hover .hex-shape {
  background: rgba(200,149,26,0.18);
}
.hex-item.hex-active .hex-shape {
  background: rgba(200,149,26,0.22);
}

/* Bordure hexagonale via ::before */
.hex-shape::before {
  content: '';
  position: absolute;
  inset: 0;
  clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);
  background: linear-gradient(135deg, rgba(200,149,26,0.45), rgba(200,149,26,0.15));
  z-index: 0;
  /* Simule une bordure hexagonale via inset shrink */
  mask: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);
}
.hex-shape::after {
  content: '';
  position: absolute;
  inset: 2px;
  clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);
  background: inherit;
  z-index: 0;
}

/* Contenu de l'hexagone */
.hex-icon {
  font-size: 30px;
  line-height: 1;
  z-index: 1;
  position: relative;
  filter: drop-shadow(0 1px 3px rgba(0,0,0,0.6));
}

/* Badge état (verrouillé, coût insuffisant) */
.hex-badge {
  position: absolute;
  top: 3px; right: 5px;
  font-size: 12px;
  z-index: 2;
  line-height: 1;
}

/* Bouton ℹ mobile */
.hex-info-btn {
  position: absolute;
  bottom: 2px; right: 2px;
  width: 16px; height: 16px;
  background: rgba(100,180,255,0.25);
  border: 1px solid rgba(100,180,255,0.5);
  border-radius: 50%;
  font-size: 9px; color: #80c0ff;
  display: flex; align-items: center; justify-content: center;
  cursor: pointer;
  z-index: 3;
  font-family: Cinzel, serif;
  font-weight: 700;
  line-height: 1;
  transition: background 0.12s;
}
.hex-info-btn:hover { background: rgba(100,180,255,0.45); }

/* Nom sous l'hexagone */
.hex-label {
  font-family: Cinzel, serif;
  font-size: 9px;
  color: rgba(200,180,140,0.7);
  text-align: center;
  white-space: nowrap;
  max-width: 72px;
  overflow: hidden;
  text-overflow: ellipsis;
}
.hex-item:not(.hex-locked):hover .hex-label { color: #f0d060; }

/* Coûts sous le label */
.hex-costs {
  display: flex;
  gap: 2px;
  flex-wrap: nowrap;
  align-items: center;
  justify-content: center;
  max-width: 74px;
}
.hex-cost-chip {
  font-size: 9px;
  padding: 1px 3px;
  border-radius: 8px;
  white-space: nowrap;
  background: rgba(80,200,80,0.12);
  color: #80e080;
  border: 1px solid rgba(80,200,80,0.2);
}
.hex-cost-chip.short {
  background: rgba(200,80,80,0.1);
  color: #e08080;
  border-color: rgba(200,80,80,0.2);
}

/* Séparateur catégorie */
.hex-separator {
  width: 1px;
  height: 60px;
  background: rgba(200,149,26,0.15);
  flex-shrink: 0;
  align-self: center;
}
.hex-cat-label {
  writing-mode: vertical-lr;
  transform: rotate(180deg);
  font-family: Cinzel, serif;
  font-size: 9px;
  color: rgba(200,149,26,0.35);
  letter-spacing: 0.1em;
  align-self: center;
  flex-shrink: 0;
}

/* ══════════════════════════════════════════════════════════
   TOOLTIP BÂTIMENT — PC (hover) + Mobile (épinglé)
══════════════════════════════════════════════════════════ */
.bld-tooltip {
  position: fixed;
  z-index: 9998;
  pointer-events: none;
  width: 240px;
  background: linear-gradient(145deg, #1c1530 0%, #0e0b1e 100%);
  border: 1px solid rgba(200,149,26,0.55);
  border-radius: 12px;
  padding: 14px 16px;
  box-shadow: 0 12px 40px rgba(0,0,0,0.85), 0 0 0 1px rgba(200,149,26,0.08);
  opacity: 0;
  transform: translateY(4px) scale(0.97);
  transition: opacity 0.14s, transform 0.14s;
}
.bld-tooltip.visible { opacity: 1; transform: translateY(0) scale(1); }
.btt-close { display: none; }

.btt-head {
  display: flex; align-items: center; gap: 10px;
  margin-bottom: 8px; padding-bottom: 8px;
  border-bottom: 1px solid rgba(200,149,26,0.18);
}
.btt-icon  { font-size: 28px; line-height: 1; flex-shrink: 0; }
.btt-title { display: flex; flex-direction: column; gap: 2px; }
.btt-name  { font-family: Cinzel, serif; font-size: 15px; color: #f0d880; font-weight: 700; line-height: 1.2; }
.btt-era   { display: inline-block; font-size: 11px; padding: 1px 6px; border-radius: 8px; font-family: Cinzel, serif; align-self: flex-start; }
.btt-era.era-2 { background: rgba(100,180,255,0.15); color: #80c8ff; border: 1px solid rgba(100,180,255,0.3); }
.btt-era.era-3 { background: rgba(200,100,255,0.15); color: #d090ff; border: 1px solid rgba(200,100,255,0.3); }
.btt-desc    { font-size: 13px; color: rgba(220,200,160,0.65); line-height: 1.5; margin-bottom: 8px; }
.btt-section { font-family: Cinzel, serif; font-size: 11px; text-transform: uppercase; letter-spacing: 1px; color: rgba(200,149,26,0.55); margin: 5px 0 4px; }
.btt-prods   { display: flex; flex-direction: column; gap: 2px; margin-bottom: 5px; }
.btt-prod    { font-size: 13px; color: #80e080; }
.btt-consume { font-size: 13px; color: #e09050; }
.btt-workers { font-size: 13px; color: rgba(200,200,200,0.45); margin-bottom: 2px; }
.btt-lvl     { font-size: 12px; color: rgba(200,149,26,0.5); margin-bottom: 5px; }
.btt-state   { font-size: 13px; padding: 4px 8px; border-radius: 6px; margin-top: 4px; }
.btt-state.ok { background: rgba(80,200,80,0.1); color: #80e080; border: 1px solid rgba(80,200,80,0.22); }
.btt-state.ko { background: rgba(200,80,80,0.08); color: #e08080; border: 1px solid rgba(200,80,80,0.18); font-size: 12px; }

/* ══════════════════════════════════════════════════════════
   VUE BÂTIMENT EXISTANT (upgrade / démolir)
══════════════════════════════════════════════════════════ */
.bp-bld-view {
  padding: 8px 14px 6px;
  display: flex;
  flex-direction: column;
  gap: 6px;
}
.bp-bld-header  { display: flex; align-items: center; gap: 10px; }
.bp-bld-glyph   { font-size: 36px; flex-shrink: 0; }
.bp-bld-name    { font-family: Cinzel, serif; font-size: 16px; color: #e8d090; }
.bp-bld-lvl     { font-size: 13px; color: rgba(255,255,255,0.4); margin-top: 1px; }
.bp-prod-badges { display: flex; gap: 5px; flex-wrap: wrap; }
.bp-prod-badge  { background: rgba(128,224,128,0.1); border: 1px solid rgba(128,224,128,0.3); border-radius: 4px; padding: 2px 7px; font-size: 13px; color: #80e080; }
.bp-adj-line    { font-size: 13px; color: #80c0ff; }
.bp-lvlbar-track{ height: 4px; background: rgba(255,255,255,0.08); border-radius: 2px; overflow: hidden; }
.bp-lvlbar-fill { height: 100%; background: linear-gradient(90deg,#c8951a,#f0c040); border-radius: 2px; transition: width 0.4s; }
.bp-bld-actions { display: flex; gap: 6px; flex-wrap: wrap; }

.bp-upgrade-btn {
  flex: 1;
  background: rgba(128,192,255,0.1);
  border: 1px solid rgba(128,192,255,0.3);
  border-radius: 8px; color: #80c0ff;
  font-family: Cinzel, serif; font-size: 14px;
  padding: 8px 10px; cursor: pointer;
  display: flex; flex-direction: column; align-items: center; gap: 2px;
  transition: background 0.15s;
}
.bp-upgrade-btn:hover { background: rgba(128,192,255,0.22); }
.bp-upgrade-cost { font-size: 12px; color: rgba(255,255,255,0.45); }
.bp-demolish-btn {
  background: rgba(200,80,80,0.1); border: 1px solid rgba(200,80,80,0.3);
  border-radius: 8px; color: #e08080; font-size: 14px; padding: 8px 12px;
  cursor: pointer; transition: background 0.15s;
}
.bp-demolish-btn:hover { background: rgba(200,80,80,0.22); }
.bp-max-lvl-tag { font-family: Cinzel, serif; font-size: 13px; color: #f0c040; padding: 7px; text-align: center; border: 1px solid rgba(240,192,64,0.3); border-radius: 6px; flex: 1; }

/* ══════════════════════════════════════════════════════════
   VUE FOUILLE (case cachée)
══════════════════════════════════════════════════════════ */
.bp-dig-view {
  padding: 6px 14px;
  display: flex;
  align-items: center;
  gap: 12px;
}
.bp-dig-info { flex: 1; }
.bp-dig-title { font-family: Cinzel, serif; font-size: 14px; color: #e8d090; margin-bottom: 4px; }
.bp-dig-sub   { font-size: 12px; color: rgba(255,255,255,0.4); }
.bp-lvlbar-track { height: 5px; background: rgba(255,255,255,0.07); border-radius: 3px; overflow:hidden; margin: 5px 0; }
.bp-lvlbar-fill  { height: 100%; border-radius: 3px; }

/* ══════════════════════════════════════════════════════════
   VUE BASE / TERRAIN
══════════════════════════════════════════════════════════ */
.bp-base-view { padding: 6px 14px; }
.bp-base-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 5px; }
.bp-base-row  { display: flex; justify-content: space-between; font-size: 14px; color: rgba(255,255,255,0.7); padding: 4px 8px; background: rgba(255,255,255,0.04); border-radius: 4px; }
.bp-locked    { cursor: not-allowed; opacity: 0.5; }
.bp-hint      { font-size: 12px; color: rgba(200,149,26,0.65); font-style: italic; margin-top: 3px; }
.bp-section-label { font-family: Cinzel, serif; font-size: 13px; color: rgba(200,149,26,0.55); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 5px; }
.bp-empty-msg { color: rgba(255,255,255,0.4); font-style: italic; font-size: 15px; padding: 8px 14px; }

/* ── Cards (route, transform, fouille) ── */
.bp-cards-row, .bp-terrain-cards { display: flex; gap: 8px; flex-wrap: wrap; padding: 4px 14px; }
.bp-card {
  background: rgba(255,255,255,0.04); border: 1px solid rgba(200,149,26,0.22);
  border-radius: 8px; padding: 10px; min-width: 120px;
  display: flex; flex-direction: column; gap: 5px; flex: 1;
  transition: border-color 0.18s;
}
.bp-card:hover { border-color: rgba(200,149,26,0.5); }
.bp-card.bp-locked { opacity: 0.55; }
.bp-card-glyph  { font-size: 30px; text-align: center; }
.bp-card-name   { font-family: Cinzel, serif; font-size: 14px; color: #e8d090; text-align: center; }
.bp-card-desc   { font-size: 12px; color: rgba(255,255,255,0.4); text-align: center; line-height: 1.4; }
.bp-card-cost   { font-size: 13px; text-align: center; }
.bp-card-extra  { font-size: 12px; color: #80c0ff; text-align: center; }
.bp-card-action {
  margin-top: 3px; background: rgba(200,149,26,0.12); border: 1px solid rgba(200,149,26,0.35);
  border-radius: 6px; color: #e8d090; font-family: Cinzel, serif; font-size: 13px;
  padding: 6px; cursor: pointer; width: 100%; transition: background 0.15s;
}
.bp-card-action:hover { background: rgba(200,149,26,0.25); }

/* Era badges */
.bp-era-badge, .bld-era { display: inline-block; font-size: 10px; padding: 1px 5px; border-radius: 8px; font-family: Cinzel, serif; }
.era-2 { background: rgba(100,180,255,0.12); color: #80c8ff; border: 1px solid rgba(100,180,255,0.25); }
.era-3 { background: rgba(200,100,255,0.12); color: #d090ff; border: 1px solid rgba(200,100,255,0.25); }

/* ══════════════════════════════════════════════════════════
   RESPONSIVE MOBILE ≤ 600px
══════════════════════════════════════════════════════════ */
@media (max-width: 600px) {
  /* Tooltip mobile : pleine largeur, au-dessus du drawer */
  .bld-tooltip {
    width: calc(100vw - 24px);
    left: 12px !important;
    right: 12px;
    bottom: calc(var(--hud-bottom-h, 52px) + 120px);
    top: auto !important;
  }
  .btt-close {
    display: block; position: absolute; top: 8px; right: 10px;
    background: none; border: none; color: rgba(255,255,255,0.4);
    font-size: 16px; cursor: pointer; padding: 2px 4px;
  }
  /* Le bouton ℹ est visible sur mobile */
  .hex-info-btn { display: flex; }
}

@media (min-width: 601px) {
  /* Sur PC le bouton ℹ est caché (tooltip au hover) */
  .hex-info-btn { display: none; }
}

/* ══════════════════════════════════════════════════════════
   PC ≥ 768px : drawer plus grand + polices plus grosses
══════════════════════════════════════════════════════════ */
@media (min-width: 768px) {
  #bp-drawer { min-height: 130px; }
  .hex-shape { width: 78px; height: 88px; }
  .hex-icon  { font-size: 34px; }
  .hex-label { font-size: 10px; max-width: 80px; }
  .hex-cost-chip { font-size: 10px; }

  .bp-drawer-title { font-size: 16px; }
  .btt-name  { font-size: 17px; }
  .btt-desc  { font-size: 14px; }
  .btt-prod, .btt-consume, .btt-workers { font-size: 14px; }
  .btt-state { font-size: 14px; }

  .bp-bld-name { font-size: 18px; }
  .bp-upgrade-btn { font-size: 16px; padding: 10px 12px; }
  .bp-upgrade-cost { font-size: 14px; }
  .bp-demolish-btn { font-size: 16px; }
}
